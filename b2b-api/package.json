{
  "name": "b2b-api",
  "version": "1.0.0",
  "description": "B2B Data Index — Cloudflare Worker API Gateway",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "kv:create": "wrangler kv:namespace create B2B_USAGE",
    "kv:create:preview": "wrangler kv:namespace create B2B_USAGE --preview",
    "kv:list": "wrangler kv:namespace list",
    "kv:usage": "wrangler kv:key list --namespace-id=REPLACE_WITH_KV_ID"
  },
  "devDependencies": {
    "wrangler": "^4.85.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
