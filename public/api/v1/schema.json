  "usage_examples": [
    {
      "description": "Find compliance tier for all markets",
      "query": "GET /api/v1/compliance.json — filter by tier field"
    },
    {
      "description": "Get benchmarks for Germany Technology C-suite",
      "query": "GET /api/v1/benchmarks.json — filter market=germany, industry=technology-software, job_title_level=c-suite"
    },
    {
      "description": "Full intelligence for Singapore",
      "query": "GET /api/v1/intelligence/singapore.json"
    },
    {
      "description": "All markets in MENA region",
      "query": "GET /api/v1/markets.json — filter region=MENA"
    }
